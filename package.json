{
  "name": "@ekaone/mcp-tools",
  "version": "0.0.3",
  "description": "MCP server exposing @ekaone utility tools for AI-assisted data masking",
  "keywords": [
    "mcp-tools",
    "stdio",
    "email",
    "card",
    "obfuscate",
    "typescript",
    "privacy",
    "security"
  ],
  "author": {
    "name": "Eka Prasetia",
    "email": "ekaone3033@gmail.com",
    "url": "https://prasetia.me"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "mcp-tools": "./dist/index.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm clean && tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build && pnpm run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ekaone/mask-card": "latest",
    "@ekaone/mask-email": "latest",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ekaone/mcp-tools.git"
  },
  "bugs": {
    "url": "https://github.com/ekaone/mcp-tools/issues"
  },
  "homepage": "https://github.com/ekaone/mcp-tools#readme"
}