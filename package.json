{
  "name": "@ekaone/mcp-tools",
  "version": "0.0.1",
  "description": "MCP server exposing ekaone utility tools for AI-assisted data masking",
  "keywords": [
    "email",
    "mask",
    "obfuscate",
    "typescript",
    "library",
    "privacy",
    "security",
    "email-masking",
    "data-protection"
  ],
  "author": {
    "name": "Eka Prasetia",
    "email": "ekaone3033@gmail.com",
    "url": "https://prasetia.me"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/server.js",
  "scripts": {
    "build": "pnpm clean && tsup src/server.ts --format esm --dts",
    "build:local": "pnpm clean && tsup src/server-local.ts --format esm --dts",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build && pnpm run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ekaone/mask-card": "latest",
    "@ekaone/mask-email": "latest",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ekaone/mcp-tools.git"
  },
  "bugs": {
    "url": "https://github.com/ekaone/mcp-tools/issues"
  },
  "homepage": "https://github.com/ekaone/mcp-tools#readme",
  "license": "MIT"
}
